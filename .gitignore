# Pi credentials / private state
.pi/agent/auth.json
.pi/agent/sessions/
.pi/agent/run-history.jsonl
.pi/agent/update-cache.json

# Local env / secret material (keep schemas and samples trackable)
.env
.env.*
!.env.example
!.env.sample
!.env.schema

# Generated dependencies and caches
**/node_modules/
.pi/agent/npm/
.pi/prompts/
**/.cache/
**/.codegraph/
**/dist/
**/build/
.superpowers/
.worktrees/

# OS/editor noise
.DS_Store
Thumbs.db
# Generated Python caches
**/__pycache__/
**/*.pyc
# Skills generated elsewhere; Pi setup keeps active skills in ~/.agents/skills
.pi/skills/
.codex/skills/
# Installed from upstream, not vendored in this dotfiles repo
.agents/skills/superpowers/
